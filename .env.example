# --- Azure OpenAI / Foundry 모델 ---
# Foundry 포털 > 프로젝트 > Models + Endpoints 에서 확인
# 엔드포인트 예: https://<your-resource>.openai.azure.com/
#               또는 https://<your-resource>.services.ai.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

# Foundry에서 만든 채팅 모델 배포 이름 (예: gpt-4o-mini)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Foundry에서 만든 임베딩 모델 배포 이름 (RAG 단계에서 사용 예정)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Server ---
PORT=3978

# --- M365 Agent SDK Auth (플레이그라운드 로컬 테스트에서는 비워둬도 OK) ---
# 실제 Copilot 채널 연결 시 Azure Bot Service에서 발급받은 값 입력
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=
