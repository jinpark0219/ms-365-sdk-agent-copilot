# =============================================================================
# Azure OpenAI / Foundry モデル
# =============================================================================
# Foundry ポータル > プロジェクト > Models + Endpoints から取得
# エンドポイント例:
#   https://<your-resource>.openai.azure.com/
#   https://<your-resource>.services.ai.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

# Foundry で作成したチャットモデルのデプロイ名 (例: gpt-4o-mini)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Foundry で作成した埋め込みモデルのデプロイ名 (RAG で使用)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# =============================================================================
# Server
# =============================================================================
# ローカル: 3978 / Azure App Service: 8000 推奨
PORT=3978

# =============================================================================
# M365 Agent SDK Auth (Entra ID)
# =============================================================================
# ローカルの Playground でのみテストする場合は空欄で OK
# Azure Bot Service / Copilot Studio と接続する場合は必須
#   - CLIENT_ID:     Entra ID で登録したアプリケーション ID
#   - CLIENT_SECRET: 同アプリで発行したシークレットの "値" (有効期限あり)
#   - TENANT_ID:     Entra ID のテナント ID
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=

# =============================================================================
# 案内文に埋め込む連絡先 (該当情報が見つからなかった場合の fallback)
# =============================================================================
# 例:
#   HR_CONTACT=HR: 内線2001
#   IT_CONTACT=IT: 内線1234 / Teams "IT Helpdesk" チャネル
HR_CONTACT=HR担当
IT_CONTACT=IT担当
