# --- Azure OpenAI / Foundry モデル ---
# Foundry ポータル > プロジェクト > Models + Endpoints から取得
# エンドポイント例: https://<your-resource>.openai.azure.com/
#                  または https://<your-resource>.services.ai.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

# Foundry で作成したチャットモデルのデプロイ名(例: gpt-4o-mini)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Foundry で作成した埋め込みモデルのデプロイ名(RAG で使用)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Server ---
PORT=3978

# --- M365 Agent SDK Auth (Playground でのローカルテスト時は空欄で OK) ---
# 実際の Copilot チャネル接続時は Azure Bot Service で発行された値を入力
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=
